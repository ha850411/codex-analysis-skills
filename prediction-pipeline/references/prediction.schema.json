{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex 主預測",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "prediction_id", "stage", "generated_at", "model", "reasoning_effort", "thesis", "probability_groups", "confidence", "key_factors", "risks", "missing_data"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "prediction_id": {"type": "string", "minLength": 1},
    "stage": {"type": "string", "const": "primary"},
    "generated_at": {"type": "string", "format": "date-time"},
    "model": {"type": "string", "minLength": 1},
    "reasoning_effort": {"type": ["string", "null"], "enum": [null, "minimal", "low", "medium", "high", "max"]},
    "thesis": {"type": "string", "minLength": 1},
    "probability_groups": {"$ref": "#/$defs/probability_groups"},
    "confidence": {"$ref": "#/$defs/confidence"},
    "key_factors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_ids", "impact", "reason"],
        "properties": {
          "evidence_ids": {"type": "array", "items": {"type": "string"}},
          "impact": {"enum": ["positive", "negative", "mixed", "uncertainty"]},
          "reason": {"type": "string"}
        }
      }
    },
    "risks": {"type": "array", "items": {"type": "string"}},
    "missing_data": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "probability_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "outcomes"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "outcomes": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["key", "label", "probability"],
              "properties": {
                "key": {"type": "string", "minLength": 1},
                "label": {"type": "string", "minLength": 1},
                "probability": {"type": "number", "minimum": 0, "maximum": 100, "multipleOf": 0.1}
              }
            }
          }
        }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "rationale", "components"],
      "properties": {
        "value": {"type": "integer", "minimum": 0, "maximum": 100},
        "rationale": {"type": "string", "minLength": 1},
        "components": {"$ref": "#/$defs/confidence_components"}
      }
    },
    "confidence_components": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data_completeness", "freshness", "lineup_certainty", "regime_relevance", "model_stability"],
      "properties": {
        "data_completeness": {"type": "number", "minimum": 0, "maximum": 100},
        "freshness": {"type": "number", "minimum": 0, "maximum": 100},
        "lineup_certainty": {"type": "number", "minimum": 0, "maximum": 100},
        "regime_relevance": {"type": "number", "minimum": 0, "maximum": 100},
        "model_stability": {"type": "number", "minimum": 0, "maximum": 100}
      }
    }
  }
}
