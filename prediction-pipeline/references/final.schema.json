{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex 最終裁決",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "prediction_id", "stage", "generated_at", "model", "reasoning_effort", "accepted_findings", "rejected_findings", "finding_adjudications", "question_resolutions", "changes", "thesis", "probability_groups", "confidence", "key_factors", "risks", "missing_data", "presentation"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "prediction_id": {"type": "string", "minLength": 1},
    "stage": {"type": "string", "const": "final"},
    "generated_at": {"type": "string", "format": "date-time"},
    "model": {"type": "string", "minLength": 1},
    "reasoning_effort": {"type": ["string", "null"], "enum": [null, "minimal", "low", "medium", "high", "max"]},
    "accepted_findings": {"type": "array", "items": {"type": "string"}},
    "rejected_findings": {"type": "array", "items": {"type": "string"}},
    "finding_adjudications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_id", "decision", "rationale", "resulting_action"],
        "properties": {
          "finding_id": {"type": "string", "minLength": 1},
          "decision": {"enum": ["accept", "reject"]},
          "rationale": {"type": "string", "minLength": 1},
          "resulting_action": {"type": "string", "minLength": 1}
        }
      }
    },
    "question_resolutions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "status", "response", "impact"],
        "properties": {
          "question": {"type": "string", "minLength": 1},
          "status": {"enum": ["resolved", "unresolved", "not_applicable"]},
          "response": {"type": "string", "minLength": 1},
          "impact": {"type": "string", "minLength": 1}
        }
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "before", "after", "reason", "finding_ids"],
        "properties": {
          "path": {"type": "string"},
          "before": {"type": "string"},
          "after": {"type": "string"},
          "reason": {"type": "string"},
          "finding_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "thesis": {"type": "string", "minLength": 1},
    "probability_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "outcomes"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "outcomes": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["key", "label", "probability"],
              "properties": {
                "key": {"type": "string", "minLength": 1},
                "label": {"type": "string", "minLength": 1},
                "probability": {"type": "number", "minimum": 0, "maximum": 100, "multipleOf": 0.1}
              }
            }
          }
        }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "rationale", "components"],
      "properties": {
        "value": {"type": "integer", "minimum": 0, "maximum": 100},
        "rationale": {"type": "string", "minLength": 1},
        "components": {
          "type": "object",
          "additionalProperties": false,
          "required": ["data_completeness", "freshness", "lineup_certainty", "regime_relevance", "model_stability"],
          "properties": {
            "data_completeness": {"type": "number", "minimum": 0, "maximum": 100},
            "freshness": {"type": "number", "minimum": 0, "maximum": 100},
            "lineup_certainty": {"type": "number", "minimum": 0, "maximum": 100},
            "regime_relevance": {"type": "number", "minimum": 0, "maximum": 100},
            "model_stability": {"type": "number", "minimum": 0, "maximum": 100}
          }
        }
      }
    },
    "key_factors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_ids", "impact", "reason"],
        "properties": {
          "evidence_ids": {"type": "array", "items": {"type": "string"}},
          "impact": {"enum": ["positive", "negative", "mixed", "uncertainty"]},
          "reason": {"type": "string"}
        }
      }
    },
    "risks": {"type": "array", "items": {"type": "string"}},
    "missing_data": {"type": "array", "items": {"type": "string"}},
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "executive_summary", "analysis_sections", "key_points", "disclaimer", "summary_table", "youtube"],
      "properties": {
        "headline": {"type": "string", "minLength": 1},
        "executive_summary": {"type": "string", "minLength": 1},
        "analysis_sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["heading", "markdown"],
            "properties": {
              "heading": {"type": "string", "minLength": 1},
              "markdown": {"type": "string", "minLength": 1}
            }
          }
        },
        "key_points": {"type": "array", "items": {"type": "string"}},
        "disclaimer": {"type": "string"},
        "summary_table": {
          "type": "object",
          "additionalProperties": false,
          "required": ["columns", "rows"],
          "properties": {
            "columns": {
              "type": "array",
              "minItems": 5,
              "items": {"type": "string", "minLength": 1}
            },
            "rows": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "array",
                "minItems": 5,
                "items": {"type": "string"}
              }
            }
          }
        },
        "youtube": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "hook", "sections", "closing"],
          "properties": {
            "title": {"type": "string", "minLength": 1},
            "hook": {"type": "string", "minLength": 1},
            "sections": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["heading", "script"],
                "properties": {
                  "heading": {"type": "string"},
                  "script": {"type": "string"}
                }
              }
            },
            "closing": {"type": "string"}
          }
        }
      }
    }
  }
}
