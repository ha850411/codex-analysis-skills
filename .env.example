# shared/notion/publish_prediction.mjs 使用的 Notion 設定
NOTION_TOKEN=
NOTION_DATA_SOURCE_ID=

# 不使用 NOTION_DATA_SOURCE_ID 時可改用以下設定：
# NOTION_DATABASE_ID=
# NOTION_PAGE_ID=

# 選用設定
NOTION_VERSION=2026-03-11
# NOTION_AUTO_PUBLISH=1
# NOTION_DRY_RUN=1
# NOTION_TABLE_LAYOUT=auto
# NOTION_PROPERTY_MAP={"prediction":"預測比分","confidence":"信心度","risk":"核心風險"}

# GitHub PAT
GITHUB_PAT=

# MLB 與 LoL 共用的報告收件信箱；多個地址以逗號分隔。
AUTOMATION_NOTIFICATION_EMAIL=you@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURITY=ssl
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=
SMTP_FROM=you@gmail.com
